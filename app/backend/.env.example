APP_NAME=AWS Customer Agreement RAG
PDF_PATH=../resources/AWS Customer Agreement.pdf
CHROMA_DIR=./data/chroma
CHROMA_COLLECTION=aws_customer_agreement
RAG_CHROMA_COLLECTION=aws_customer_agreement_rag_chunks
SQLITE_PATH=./data/usage.db
GRAPH_SQLITE_PATH=./data/graph.db
CHUNK_SIZE=900
CHUNK_OVERLAP=150
DEFAULT_TOP_K=5
DEFAULT_NEIGHBORS=1

OPENAI_EMBEDDING_BASE_URL=http://localhost:11434/v1
OPENAI_EMBEDDING_MODEL=qwen3-embedding:4b
OPENAI_EMBEDDING_API_KEY=

OPENAI_CHAT_BASE_URL=https://integrate.api.nvidia.com/v1
